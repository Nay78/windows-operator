{
  "name": "windows-operator-powerpoint-addin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Office.js PowerPoint add-in hosted by Windows Operator.",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3003",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3003",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "manifest:validate": "npx --yes office-addin-manifest@2.1.5 validate manifest.xml"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/office-js": "^1.0.592",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  }
}
